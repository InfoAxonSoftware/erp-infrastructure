####################################
# Project
####################################

COMPOSE_PROJECT_NAME=erp-platform
TZ=Asia/Colombo

####################################
# Domain
####################################

# Company website domain handled by Nginx/Let's Encrypt.
# The current SSL helper supports infoaxon.lk and www.infoaxon.lk.
DOMAIN=infoaxon.lk

# Nginx template profile. deploy.sh starts with HTTP; setup-ssl.sh switches this
# to https after certificates are issued and copied into ssl/live/infoaxon.lk/.
NGINX_TEMPLATE_PROFILE=http

####################################
# PostgreSQL
####################################

# The default/maintenance database (leave as "postgres")
POSTGRES_DB=postgres

# Database user Odoo connects with
POSTGRES_USER=odoo

# REQUIRED: Replace with a strong random password (min 32 chars)
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# Separate credentials for the company website database (never reuse Odoo's DB).
WEBSITE_DB_NAME=infoaxon_website
WEBSITE_DB_USER=infoaxon_web
# Use URL-safe characters because this is embedded in Prisma's DATABASE_URL.
# Generate: openssl rand -hex 32
WEBSITE_DB_PASSWORD=CHANGE_ME

####################################
# Odoo
####################################

# REQUIRED: Master password for the Odoo database manager (keep very secret)
# Generate: openssl rand -base64 32
ODOO_ADMIN_PASSWORD=CHANGE_ME

# Current Odoo demo database expected by config/odoo/odoo.conf dbfilter.
ODOO_DEMO_DATABASE=infoaxon_erp

####################################
# React Frontend (external repo)
####################################

# REQUIRED: Git URL of your React website repository
# Examples:
#   HTTPS (public repo):   https://github.com/yourorg/your-react-website.git
#   SSH   (private repo):  git@github.com:yourorg/your-react-website.git
REACT_REPO_URL=https://github.com/yourorg/your-react-website.git

# Optional: branch or tag to deploy (defaults to the repo's HEAD)
# REACT_BRANCH=main

####################################
# Backup
####################################

# Number of days to retain local backups before automatic cleanup
BACKUP_RETENTION_DAYS=14

# Optional: S3 bucket name for off-site backup upload
# Leave empty to disable S3 uploads
# Requires aws CLI installed and configured on the server
S3_BUCKET=

####################################
# Ports (development only)
####################################

# Odoo is temporarily exposed directly on SERVER_IP:8069 for demos.
# PostgreSQL and Odoo gevent/8072 must remain private.
