####################################
# Project
####################################

COMPOSE_PROJECT_NAME=erp-platform
TZ=Asia/Colombo

####################################
# Domain
####################################

# Your root domain. All tenant subdomains are automatically derived from this.
# example: yourerp.com  →  erp.yourerp.com (Odoo), *.yourerp.com (tenants)
DOMAIN=yourerp.com

####################################
# PostgreSQL
####################################

# The default/maintenance database (leave as "postgres")
POSTGRES_DB=postgres

# Database user Odoo connects with (must have CREATEDB for multi-tenant provisioning)
POSTGRES_USER=odoo

# REQUIRED: Replace with a strong random password (min 32 chars)
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

####################################
# Odoo
####################################

# REQUIRED: Master password for the Odoo database manager (keep very secret)
# Generate: openssl rand -base64 32
ODOO_ADMIN_PASSWORD=CHANGE_ME

####################################
# React Frontend (external repo)
####################################

# REQUIRED: Git URL of your React website repository
# Examples:
#   HTTPS (public repo):   https://github.com/yourorg/your-react-website.git
#   SSH   (private repo):  git@github.com:yourorg/your-react-website.git
REACT_REPO_URL=https://github.com/yourorg/your-react-website.git

# Optional: branch or tag to deploy (defaults to the repo's HEAD)
# REACT_BRANCH=main

####################################
# Backup
####################################

# Number of days to retain local backups before automatic cleanup
BACKUP_RETENTION_DAYS=14

# Optional: S3 bucket name for off-site backup upload
# Leave empty to disable S3 uploads
# Requires aws CLI installed and configured on the server
S3_BUCKET=

####################################
# Ports (development only)
####################################

# These are NOT used in production (Nginx handles routing on 80/443).
# Uncomment for local development access.
# ODOO_PORT=8069
# POSTGRES_PORT=5432