# Copy this file to .env.production and replace every CHANGE_ME value.
# The populated .env.production is gitignored and must never be committed.
# DATABASE_URL, NODE_ENV, and PORT are supplied by Docker Compose.
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
CLIENT_URL=https://infoaxon.lk
INITIAL_ADMIN_USERNAME=ADMIN
INITIAL_ADMIN_PASSWORD=CHANGE_ME
UPLOAD_MAX_SIZE=5242880
